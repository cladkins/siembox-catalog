{
  "schema": "siembox.parser/v1",
  "name": "Apache/Nginx Access Log",
  "description": "Parses standard Apache/Nginx access logs",
  "parser_type": "regex",
  "priority": 20,
  "pattern": "^(?<client_ip>[\\d.]+)\\s+-\\s+-\\s+\\[(?<timestamp>[^\\]]+)\\]\\s+\"(?<method>\\S+)\\s+(?<path>\\S+)\\s+(?<protocol>[^\"]+)\"\\s+(?<status>\\d+)\\s+(?<size>\\d+)",
  "field_mappings": {
    "client_ip": "client_ip",
    "timestamp": "timestamp",
    "method": "method",
    "path": "path",
    "protocol": "protocol",
    "status_code": "status",
    "response_size": "size"
  },
  "event_type": "http_request",
  "enabled": true,
  "test_samples": [
    {
      "description": "Common Log Format GET returning 200",
      "input": "203.0.113.5 - - [15/Jan/2024:12:00:00 +0000] \"GET /index.html HTTP/1.1\" 200 1024",
      "expect": {
        "client_ip": "203.0.113.5",
        "source_ip": "203.0.113.5",
        "method": "GET",
        "path": "/index.html",
        "status_code": "200",
        "service": "nginx"
      }
    },
    {
      "description": "404 probe for a PHP file (common scanner behavior)",
      "input": "198.51.100.9 - - [15/Jan/2024:12:01:00 +0000] \"GET /admin.php HTTP/1.1\" 404 512",
      "expect": {
        "client_ip": "198.51.100.9",
        "source_ip": "198.51.100.9",
        "method": "GET",
        "path": "/admin.php",
        "status_code": "404",
        "service": "nginx"
      }
    }
  ],
  "metadata": {
    "author": "siembox",
    "log_source": "Apache/Nginx access log (Common Log Format)",
    "tags": [
      "http",
      "webserver",
      "apache",
      "nginx"
    ],
    "references": [
      "https://httpd.apache.org/docs/current/logs.html#common"
    ]
  }
}
