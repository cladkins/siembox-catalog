{
  "schema": "siembox.parser/v1",
  "name": "fail2ban",
  "parser_type": "regex",
  "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2},\\d{3} fail2ban\\.actions\\s+\\[\\d+\\]:\\s+\\w+\\s+\\[(?<jail>[^\\]]+)\\]\\s+(?<action>Ban|Unban)\\s+(?<source_ip>\\d{1,3}(?:\\.\\d{1,3}){3})\\s*$",
  "field_mappings": {
    "jail": "service",
    "action": "fail2ban_action",
    "source_ip": "source_ip"
  },
  "description": "Parses Fail2ban action log lines (fail2ban.actions) for Ban/Unban events, capturing the jail, the offending source IP, and a normalized event (ip_banned / ip_unbanned).",
  "priority": 80,
  "derivations": [
    {
      "set": {
        "event": "ip_banned"
      },
      "when": {
        "fail2ban_action": {
          "equals": "Ban"
        }
      }
    },
    {
      "set": {
        "event": "ip_unbanned"
      },
      "when": {
        "fail2ban_action": {
          "equals": "Unban"
        }
      }
    }
  ],
  "event_type": "intrusion_prevention",
  "enabled": true,
  "test_samples": [
    {
      "input": "2024-01-15 13:45:12,123 fail2ban.actions        [1234]: NOTICE  [sshd] Ban 203.0.113.45",
      "expect": {
        "event": "ip_banned",
        "service": "sshd",
        "source_ip": "203.0.113.45",
        "fail2ban_action": "Ban"
      },
      "description": "Ban action from the sshd jail (padded formatting)"
    },
    {
      "input": "2024-01-16 09:02:30,000 fail2ban.actions        [1234]: NOTICE  [sshd] Unban 203.0.113.45",
      "expect": {
        "event": "ip_unbanned",
        "service": "sshd",
        "source_ip": "203.0.113.45"
      },
      "description": "Unban action from the sshd jail"
    },
    {
      "input": "2024-02-01 22:14:05,777 fail2ban.actions [9876]: WARNING [nginx-http-auth] Ban 198.51.100.23",
      "expect": {
        "event": "ip_banned",
        "service": "nginx-http-auth",
        "source_ip": "198.51.100.23"
      },
      "description": "Ban from a different jail, single-space formatting variant"
    }
  ]
}
