{
  "schema": "siembox.parser/v1",
  "name": "nginx-komodo-timestamp-first",
  "parser_type": "regex",
  "pattern": "^\\[(?<timestamp>[^\\]]+)\\]\\s+(?:-\\s+)?(?<status_code1>\\d{3})?\\s*(?<status_code2>\\d{3})?\\s*-?\\s*(?<method>GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE)?\\s*(?<protocol>https?|wss?)?\\s*(?<request_uri>\\S+)?",
  "field_mappings": {
    "method": "method",
    "service": "nginx-komodo",
    "protocol": "protocol",
    "timestamp": "timestamp",
    "request_uri": "request_uri",
    "status_code": "status_code1",
    "upstream_status": "status_code2"
  },
  "description": "Parses custom NGINX access logs from komodo that start with timestamp",
  "priority": 45,
  "event_type": "http_request",
  "enabled": true,
  "test_samples": [
    {
      "input": "[15/Jan/2024:12:00:00 +0000] - 200 200 - GET https /api/health",
      "expect": {
        "path": "/api/health",
        "method": "GET",
        "service": "nginx",
        "status_code": "200",
        "upstream_status": "200"
      },
      "description": "timestamp-first access line with response and upstream status"
    },
    {
      "input": "[15/Jan/2024:12:01:00 +0000] 404 - GET https /missing",
      "expect": {
        "path": "/missing",
        "method": "GET",
        "service": "nginx",
        "status_code": "404"
      },
      "description": "404 line, single status code"
    }
  ]
}
