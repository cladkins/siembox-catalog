{
  "schema": "siembox.parser/v1",
  "name": "unifi-firewall",
  "description": "Parses Ubiquiti UniFi (UCG-Max) firewall rule logs for network security monitoring",
  "parser_type": "regex",
  "priority": 50,
  "pattern": "\\[(?<rule_name>[^\\]]+)\\].*?DESCR=\"(?<rule_description>[^\"]+)\".*?IN=(?<in_interface>\\S+).*?OUT=(?<out_interface>\\S*).*?SRC=(?<source_ip>[\\d\\.]+).*?DST=(?<dest_ip>[\\d\\.]+).*?PROTO=(?<protocol>\\w+)",
  "field_mappings": {
    "rule_name": "rule_name",
    "rule_description": "rule_description",
    "in_interface": "in_interface",
    "out_interface": "out_interface",
    "source_ip": "source_ip",
    "client_ip": "source_ip",
    "dest_ip": "dest_ip",
    "destination_ip": "dest_ip",
    "protocol": "protocol",
    "service": "unifi-firewall"
  },
  "event_type": "firewall_event",
  "enabled": true,
  "test_samples": [
    {
      "description": "WAN_IN drop rule logs source, destination, and protocol",
      "input": "Jan 15 12:00:00 UCG-Max kernel: [LAN_LOCAL-WAN_IN-2000] DESCR=\"Drop Invalid\" IN=eth4 OUT= MAC=aa:bb:cc:dd:ee:ff SRC=203.0.113.5 DST=198.51.100.10 LEN=60 TOS=0x00 TTL=52 ID=12345 PROTO=TCP SPT=44321 DPT=22",
      "expect": {
        "rule_name": "LAN_LOCAL-WAN_IN-2000",
        "rule_description": "Drop Invalid",
        "source_ip": "203.0.113.5",
        "client_ip": "203.0.113.5",
        "dest_ip": "198.51.100.10",
        "protocol": "TCP",
        "service": "unifi"
      }
    }
  ],
  "metadata": {
    "author": "siembox",
    "log_source": "Ubiquiti UniFi gateway firewall log (iptables LOG via syslog)",
    "tags": [
      "firewall",
      "network",
      "unifi",
      "ubiquiti"
    ],
    "references": [
      "https://help.ui.com/hc/en-us/articles/204959834-UniFi-Remote-Logging-Syslog"
    ]
  }
}
