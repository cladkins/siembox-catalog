{
  "schema": "siembox.parser/v1",
  "name": "unifi-idsips",
  "description": "Parses Ubiquiti UniFi IDS/IPS daemon event logs for intrusion detection and prevention",
  "parser_type": "regex",
  "priority": 50,
  "pattern": "ubnt-idsips-daemon\\[\\d+\\]:\\s+[\\d-]+T[\\d:.-]+\\s+(?<severity>\\w+):\\s+(?<event_type>.+?):\\s+ipset\\[(?<action_type>\\w+)\\]\\s+(?<action>\\w+)\\s+failed\\s+ip1:(?<external_ip>[\\d.]+),\\s+port1:(?<external_port>\\d+),\\s+ip2:(?<internal_ip>[\\d.]+),\\s+port2:(?<internal_port>\\d+),\\s+proto:(?<protocol>\\w+)",
  "field_mappings": {
    "severity": "severity",
    "log_level": "severity",
    "event_type": "event_type",
    "action_type": "action_type",
    "action": "action",
    "external_ip": "external_ip",
    "source_ip": "external_ip",
    "client_ip": "external_ip",
    "external_port": "external_port",
    "source_port": "external_port",
    "internal_ip": "internal_ip",
    "dest_ip": "internal_ip",
    "destination_ip": "internal_ip",
    "internal_port": "internal_port",
    "dest_port": "internal_port",
    "protocol": "protocol",
    "service": "unifi-idsips"
  },
  "event_type": "ids_alert",
  "enabled": true,
  "test_samples": [
    {
      "description": "IPS alert maps external (source) and internal (dest) IPs and ports",
      "input": "Jan 15 12:00:00 UDMP ubnt-idsips-daemon[1234]: 2024-01-15T12:00:00.123-00:00 ALERT: ET SCAN Suspicious inbound: ipset[add] block failed ip1:203.0.113.5, port1:55000, ip2:198.51.100.10, port2:443, proto:TCP",
      "expect": {
        "severity": "ALERT",
        "action": "block",
        "source_ip": "203.0.113.5",
        "client_ip": "203.0.113.5",
        "source_port": "55000",
        "dest_ip": "198.51.100.10",
        "dest_port": "443",
        "protocol": "TCP",
        "service": "unifi"
      }
    }
  ],
  "metadata": {
    "author": "siembox",
    "log_source": "Ubiquiti UniFi IDS/IPS daemon log (ubnt-idsips-daemon via syslog)",
    "tags": [
      "ids",
      "ips",
      "intrusion-detection",
      "unifi",
      "ubiquiti"
    ],
    "references": [
      "https://help.ui.com/hc/en-us/articles/360006893234-UniFi-Gateway-Intrusion-Detection-and-Prevention-IDS-IPS"
    ]
  }
}
